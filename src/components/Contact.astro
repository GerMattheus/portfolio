---
import DnaHelix from './DnaHelix.astro';

const email = "germanofataki243@gmail.com";
const location = "Sherbrooke, QC";

const links = [
  { label: "GitHub", href: "https://github.com/GerMattheus" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/mattheusgermano" },
];
---

<section class="contact" id="contact" aria-labelledby="contact-heading">

  <!-- Hélice décorative droite -->
  <div class="contact-helix" aria-hidden="true">
    <DnaHelix />
  </div>

  <!-- Contenu -->
  <div class="contact-inner">

    <p class="contact-label" id="contact-heading">06 · Contact</p>

    <div class="contact-body">

      <a class="contact-email" href={`mailto:${email}`} aria-label={`Envoyer un email à ${email}`}>
        {email}
      </a>

      <div class="contact-details">
        <span class="contact-location">{location}</span>
        <div class="contact-links" role="list">
          {links.map(l => (
            <a
              class="contact-link"
              href={l.href}
              target="_blank"
              rel="noopener noreferrer"
              role="listitem"
            >
              {l.label} ↗
            </a>
          ))}
          <a
            class="contact-link contact-link--cv"
            href="/cv.pdf"
            download
            aria-label="Télécharger le CV (PDF)"
            role="listitem"
          >
            CV ↓
          </a>
        </div>
      </div>

    </div>

  </div>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <span class="footer-name">Mattheus Germano</span>
    <span class="footer-sep" aria-hidden="true">·</span>
    <span class="footer-copy">2026</span>
    <span class="footer-sep" aria-hidden="true">·</span>
    <span class="footer-built">Built with care · Sherbrooke</span>
  </footer>

</section>

<style>
  .contact {
    position: relative;
    background-color: var(--bg-primary);
    padding-top: var(--space-12);
    overflow: hidden;
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 767px) {
    .contact { padding-top: var(--space-8); }
  }

  /* ── Hélice décorative ───────────────────────────── */
  .contact-helix {
    display: none;
    position: absolute;
    right: var(--space-16);
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }

  @media (min-width: 768px) {
    .contact-helix { display: block; }
  }

  /* ── Contenu ─────────────────────────────────────── */
  .contact-inner {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-8);
    padding-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (max-width: 767px) {
    .contact-inner {
      padding-inline: var(--space-4);
      padding-bottom: var(--space-6);
      gap: var(--space-4);
    }
  }

  /* ── Label section ───────────────────────────────── */
  .contact-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── Corps ───────────────────────────────────────── */
  .contact-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-email {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--text-primary);
    text-decoration: none;
    position: relative;
    display: inline-block;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .contact-email::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent-cool);
    transition: width var(--duration-base) var(--ease-out);
  }

  .contact-email:hover { color: var(--accent-cool); }
  .contact-email:hover::after { width: 100%; }

  .contact-details {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-location {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  .contact-links {
    display: flex;
    gap: var(--space-4);
  }

  .contact-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .contact-link:hover { color: var(--accent-cool); }

  /* Lien CV — légèrement mis en valeur */
  .contact-link--cv {
    color: var(--accent-primary);
    border: 1px solid var(--border);
    padding: 1px 8px;
  }

  .contact-link--cv:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  /* ── Footer ──────────────────────────────────────── */
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-4) var(--space-8);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 767px) {
    .site-footer {
      padding: var(--space-4);
      gap: var(--space-2);
    }
  }

  .footer-name,
  .footer-copy,
  .footer-built {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  .footer-sep { color: var(--border); }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.contact-label', {
      opacity: 0, y: 24, duration: 0.7,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.contact-inner', start: 'top 82%', once: true },
    });

    gsap.from('.contact-email', {
      opacity: 0, y: 16, duration: 0.6,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.contact-body', start: 'top 85%', once: true },
    });

    gsap.from('.contact-details', {
      opacity: 0, y: 12, duration: 0.5, delay: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.contact-body', start: 'top 85%', once: true },
    });
  }
</script>
