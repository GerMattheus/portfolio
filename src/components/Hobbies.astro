---
interface HobbyItem {
  label: string;
  links?: { text: string; href: string }[];
}

interface Category {
  keyword: string;
  items: HobbyItem[];
}

const categories: Category[] = [
  {
    keyword: "Sport",
    items: [
      { label: "Basketball" },
      { label: "Soccer" },
      { label: "Échecs", links: [
        { text: "Chess.com", href: "https://www.chess.com/member/Germano243" },
        { text: "Lichess", href: "https://lichess.org/@/Docteur-Poison" },
      ]},
    ],
  },
  {
    keyword: "Lecture",
    items: [
      { label: "Romans d'aventure" },
      { label: "Horreur" },
      { label: "Policier" },
      { label: "Mystère" },
      { label: "Mangas" },
    ],
  },
  {
    keyword: "Cinéma",
    items: [
      { label: "Science-fiction" },
      { label: "Animation japonaise" },
      { label: "Action" },
      { label: "Mystère" },
      { label: "Aventure" },
      { label: "Letterboxd", links: [
        { text: "Letterboxd", href: "https://letterboxd.com/DocteurPoison" },
      ]},
    ],
  },
];
---

<section class="hobbies" id="hobbies" aria-labelledby="hobbies-heading">

  <div class="hobbies-inner">

    <p class="hobbies-label" id="hobbies-heading">05 · Intérêts</p>

    <div class="hobbies-grid">
      {categories.map((cat, i) => (
        <div class="hobby-col">
          <span class="hobby-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}.</span>
          <h3 class="hobby-keyword">{cat.keyword}</h3>
          <ul class="hobby-list" role="list">
            {cat.items.map(item => (
              <li class="hobby-item">
                {item.links ? (
                  <span class="hobby-item-links">
                    <span class="hobby-item-label">{item.label}</span>
                    {item.links.map(link => (
                      <a
                        class="hobby-link"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.text} ↗
                      </a>
                    ))}
                  </span>
                ) : (
                  item.label
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>

</section>

<style>
  .hobbies {
    background-color: var(--bg-primary);
    padding-block: var(--space-12);
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 767px) {
    .hobbies { padding-block: var(--space-8); }
  }

  .hobbies-inner {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (max-width: 767px) {
    .hobbies-inner {
      padding-inline: var(--space-4);
      gap: var(--space-4);
    }
  }

  /* ── Label section ───────────────────────────────── */
  .hobbies-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── Grille 3 colonnes ───────────────────────────── */
  .hobbies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-8);
  }

  @media (max-width: 767px) {
    .hobbies-grid { grid-template-columns: 1fr; }
  }

  /* ── Colonne ─────────────────────────────────────── */
  .hobby-col {
    padding: var(--space-6);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hobby-col:last-child { border-right: none; }

  @media (max-width: 767px) {
    .hobby-col {
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
      padding: var(--space-4) 0;
    }
    .hobby-col:last-child { border-bottom: none; }
  }

  .hobby-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .hobby-keyword {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h2);
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  /* ── Liste ───────────────────────────────────────── */
  .hobby-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-top: var(--space-1);
  }

  .hobby-item {
    font-size: var(--text-small);
    color: var(--text-secondary);
    line-height: 1.6;
    padding-left: var(--space-3);
    position: relative;
  }

  .hobby-item::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  /* Items avec liens — layout flex */
  .hobby-item-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .hobby-item-label {
    color: var(--text-secondary);
  }

  /* Liens externes */
  .hobby-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 1px 7px;
    transition: color var(--duration-micro) var(--ease-out), border-color var(--duration-micro) var(--ease-out);
    line-height: 1.7;
  }

  .hobby-link:hover {
    color: var(--accent-cool);
    border-color: var(--accent-cool);
  }

  .hobby-link:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.hobbies-label', {
      opacity: 0, y: 20, duration: 0.6, ease: 'power2.out',
      scrollTrigger: { trigger: '.hobbies-inner', start: 'top 82%', once: true },
    });

    gsap.from('.hobby-col', {
      opacity: 0, y: 24, duration: 0.55, stagger: 0.15, ease: 'power2.out',
      scrollTrigger: { trigger: '.hobbies-grid', start: 'top 80%', once: true },
    });
  }
</script>
