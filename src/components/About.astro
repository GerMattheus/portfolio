---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="about-inner">

    <p class="about-label" aria-hidden="true">01 · À propos</p>

    <p class="about-lede" id="about-heading">
      J'ai commencé en médecine à Kinshasa. Aujourd'hui, j'apprends à coder à Sherbrooke.
    </p>

    <div class="about-body">
      <p>
        Après deux ans à l'Université de Kinshasa, je suis venu au Canada pour étudier
        l'informatique à l'Université de Sherbrooke en régime coopératif.
      </p>
      <p>
        Ce qui m'intéresse aujourd'hui, c'est d'apprendre à construire des systèmes :
        des applications web, des moteurs de jeu, des outils qui résolvent un vrai
        problème. Je casse, je recommence, je documente ce que j'apprends sur ce site.
      </p>
      <p>
        Je cherche un premier stage pour mettre les mains dans des projets concrets
        et apprendre auprès de gens qui font le métier depuis plus longtemps que moi.
      </p>
    </div>

  </div>
</section>

<style>
  .about {
    background-color: var(--bg-primary);
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--border-subtle);
  }

  @media (max-width: 767px) {
    .about { padding-block: var(--space-6); }
  }

  /* ── Conteneur lecture ───────────────────────────── */
  .about-inner {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (max-width: 767px) {
    .about-inner { padding-inline: var(--space-4); }
  }

  /* ── Label ───────────────────────────────────────── */
  .about-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── Lede ────────────────────────────────────────── */
  .about-lede {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h3);
    line-height: 1.4;
    color: var(--text-primary);
  }

  /* ── Corps ───────────────────────────────────────── */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-body p {
    color: var(--text-secondary);
    line-height: 1.72;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.about-label, .about-lede', {
      opacity: 0, y: 20, duration: 0.65, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.about-inner', start: 'top 82%', once: true },
    });

    gsap.from('.about-body p', {
      opacity: 0, y: 16, duration: 0.6, stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.about-body', start: 'top 82%', once: true },
    });
  }
</script>
