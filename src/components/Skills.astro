---
const technical: Array<{ label: string; size: string }> = [
  { label: "Python",       size: "2.4rem"  },
  { label: "Java",         size: "2rem"    },
  { label: "PostgreSQL",   size: "1.75rem" },
  { label: "RStudio",      size: "1.6rem"  },
  { label: "Excel (VBA)",  size: "1.3rem"  },
  { label: "HTML / CSS",   size: "1.2rem"  },
  { label: "Suite Office", size: "1rem"    },
];

const methodological = [
  "Résolution de problèmes complexes",
  "Approche méthodique",
  "Planification & gestion de priorités",
  "Travail d'équipe",
  "Écoute active",
];
---

<section class="skills" id="skills" aria-labelledby="skills-heading">

  <!-- Image droite — Modèle A — 04-skills-cells-green assombrie -->
  <div class="skills-image" aria-hidden="true">
    <img
      src="/images/04-skills-cells-green.jpg"
      alt=""
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Contenu gauche -->
  <div class="skills-content">

    <p class="skills-label" aria-hidden="true">03 · Compétences</p>
    <h2 class="skills-title" id="skills-heading">Ce que je maîtrise</h2>

    <div class="skills-group">
      <h3 class="group-title">Techniques</h3>
      <div class="skills-cloud technical">
        {technical.map(s => (
          <span class="skill-tag skill-tech" style={`font-size: ${s.size};`}>
            {s.label}
          </span>
        ))}
      </div>
    </div>

    <div class="skills-group">
      <h3 class="group-title">Méthodologiques</h3>
      <div class="skills-cloud methodological">
        {methodological.map((s, i) => (
          <>
            <span class="skill-tag skill-method">{s}</span>
            {i < methodological.length - 1 && (
              <span class="skill-separator" aria-hidden="true">·</span>
            )}
          </>
        ))}
      </div>
    </div>

  </div>

</section>

<style>
  .skills {
    position: relative;
    background-color: var(--bg-primary);
    padding-block: var(--space-16);
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .skills { padding-block: var(--space-12); }
  }

  /* ── Image droite (Modèle A) ─────────────────────── */
  .skills-image {
    position: absolute;
    right: 0;
    top: 0;
    width: 58%;
    height: 100%;
    z-index: 0;
  }

  /* Gradient progressif + overlay pour atténuer le vert dominant */
  .skills-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #000000 0%,
      rgba(0, 0, 0, 0.92) 18%,
      rgba(0, 0, 0, 0.65) 40%,
      rgba(0, 0, 0, 0.25) 68%,
      rgba(0, 0, 0, 0.1) 85%,
      transparent 100%
    );
    z-index: 1;
  }

  .skills-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Assombrit fortement + désature le vert */
    filter: brightness(0.38) saturate(0.55);
  }

  @media (max-width: 767px) {
    .skills-image {
      width: 100%;
    }

    .skills-image::after {
      background: rgba(0, 0, 0, 0.88);
    }
  }

  /* ── Contenu gauche ──────────────────────────────── */
  .skills-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    padding-left: var(--space-8);
    padding-right: var(--space-4);
  }

  @media (max-width: 767px) {
    .skills-content {
      max-width: 100%;
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
  }

  .skills-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .skills-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h1);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-8);
  }

  .skills-group {
    margin-bottom: var(--space-8);
  }

  .group-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: var(--space-2);
  }

  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3) var(--space-4);
  }

  .skill-tech {
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-primary);
    line-height: 1;
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-tech:hover {
    color: var(--accent-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  .skills-cloud.methodological {
    align-items: center;
    gap: var(--space-2);
  }

  .skill-method {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: var(--text-body);
    color: var(--text-secondary);
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-method:hover {
    color: var(--text-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  .skill-separator {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  @keyframes heartbeat {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.08); }
    55%  { transform: scale(0.97); }
    75%  { transform: scale(1.04); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-tech:hover,
    .skill-method:hover { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.skills-label, .skills-title', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.skills-content', start: 'top 82%', once: true },
    });

    gsap.from('.skill-tech', {
      opacity: 0, y: 12, duration: 0.5,
      stagger: { amount: 0.5, from: 'start' },
      ease: 'power2.out',
      scrollTrigger: { trigger: '.technical', start: 'top 80%', once: true },
    });

    gsap.from('.skill-method, .skill-separator', {
      opacity: 0, duration: 0.5,
      stagger: { amount: 0.4, from: 'start' },
      ease: 'power2.out',
      scrollTrigger: { trigger: '.methodological', start: 'top 80%', once: true },
    });

    gsap.to('.skills-image img', {
      y: '12%', ease: 'none',
      scrollTrigger: {
        trigger: '.skills', start: 'top bottom', end: 'bottom top', scrub: true,
      },
    });
  }
</script>
