---
const languages: Array<{ label: string; tier: 1 | 2 | 3 }> = [
  { label: "Python",           tier: 1 },
  { label: "TypeScript",       tier: 1 },
  { label: "Java",             tier: 2 },
  { label: "C",                tier: 2 },
  { label: "C++",              tier: 2 },
  { label: "JavaScript",       tier: 3 },
  { label: "SQL / PostgreSQL", tier: 3 },
];

const frameworks = ["React", "Astro", "TailwindCSS", "pygame", "python-chess"];

const tools = ["Git / GitHub", "Linux", "Vite", "Vitest"];

const domains = [
  "Bio-informatique",
  "Programmation système",
  "Machine learning appliqué",
  "Développement web",
];

const tierSize: Record<1 | 2 | 3, string> = {
  1: "2rem",
  2: "1.5rem",
  3: "1.1rem",
};
---

<section class="skills" id="skills" aria-labelledby="skills-heading">
  <div class="skills-inner">

    <!-- En-tête pleine largeur -->
    <div class="skills-header">
      <p class="skills-label" aria-hidden="true">03 · Compétences</p>
      <h2 class="skills-title" id="skills-heading">Ce que je maîtrise</h2>
    </div>

    <!-- Grille 2×2 des sous-sections -->
    <div class="subsections-grid">

      <!-- LANGAGES -->
      <div class="skills-subsection">
        <p class="subsection-label">Langages</p>
        <div class="skills-cloud lang-cloud">
          {languages.map(l => (
            <span
              class={`skill-badge skill-lang skill-lang--tier-${l.tier}`}
              style={`font-size: ${tierSize[l.tier]};`}
            >
              {l.label}
            </span>
          ))}
        </div>
      </div>

      <!-- FRAMEWORKS & BIBLIOTHÈQUES -->
      <div class="skills-subsection">
        <p class="subsection-label">Frameworks &amp; Bibliothèques</p>
        <div class="skills-cloud">
          {frameworks.map(f => (
            <span class="skill-badge skill-fw">{f}</span>
          ))}
        </div>
      </div>

      <!-- OUTILS -->
      <div class="skills-subsection">
        <p class="subsection-label">Outils</p>
        <div class="skills-cloud">
          {tools.map(t => (
            <span class="skill-badge skill-tool">{t}</span>
          ))}
        </div>
      </div>

      <!-- DOMAINES D'INTÉRÊT -->
      <div class="skills-subsection">
        <p class="subsection-label">Domaines d'intérêt</p>
        <div class="skills-cloud">
          {domains.map(d => (
            <span class="skill-badge skill-domain">{d}</span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .skills {
    background-color: var(--bg-primary);
    padding-block: var(--space-16);
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 767px) {
    .skills { padding-block: var(--space-12); }
  }

  /* ── Conteneur ───────────────────────────────────── */
  .skills-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (max-width: 767px) {
    .skills-inner { padding-inline: var(--space-4); }
  }

  /* ── En-tête ──────────────────────────────────────── */
  .skills-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .skills-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h1);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  /* ── Grille 2×2 ──────────────────────────────────── */
  .subsections-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-8);
  }

  @media (max-width: 767px) {
    .subsections-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Sous-section ────────────────────────────────── */
  .skills-subsection {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .subsection-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ── Cloud de badges ─────────────────────────────── */
  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .lang-cloud {
    align-items: flex-end; /* aligne les baselines en bas pour la hiérarchie de taille */
  }

  /* ── Badge de base ───────────────────────────────── */
  .skill-badge {
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid var(--border);
    padding: 3px 10px;
    line-height: 1.5;
    cursor: default;
    transition:
      color var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out);
  }

  /* ── Langages — hiérarchie par tier ─────────────── */
  .skill-lang--tier-1 {
    color: var(--text-primary);
    border-color: var(--border);
  }

  .skill-lang--tier-2 {
    color: var(--text-secondary);
    border-color: var(--border);
  }

  .skill-lang--tier-3 {
    color: var(--text-muted);
    border-color: var(--border-subtle);
  }

  .skill-lang:hover {
    color: var(--accent-primary) !important;
    border-color: var(--accent-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Frameworks ──────────────────────────────────── */
  .skill-fw {
    font-size: 1rem;
    color: var(--text-primary);
  }

  .skill-fw:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Outils ──────────────────────────────────────── */
  .skill-tool {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .skill-tool:hover {
    color: var(--text-primary);
    border-color: var(--text-muted);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Domaines ────────────────────────────────────── */
  .skill-domain {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--text-secondary);
    border-color: var(--border-subtle);
  }

  .skill-domain:hover {
    color: var(--text-primary);
    border-color: var(--border);
    animation: heartbeat 0.45s var(--ease-out);
  }

  @keyframes heartbeat {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.06); }
    55%  { transform: scale(0.98); }
    75%  { transform: scale(1.03); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-lang:hover,
    .skill-fw:hover,
    .skill-tool:hover,
    .skill-domain:hover { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.skills-label, .skills-title', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.skills-header', start: 'top 82%', once: true },
    });

    gsap.from('.skills-subsection', {
      opacity: 0, y: 18, duration: 0.55, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.subsections-grid', start: 'top 80%', once: true },
    });

    gsap.from('.skill-lang', {
      opacity: 0, y: 10, duration: 0.45,
      stagger: { amount: 0.4, from: 'start' },
      ease: 'power2.out',
      scrollTrigger: { trigger: '.lang-cloud', start: 'top 82%', once: true },
    });
  }
</script>
