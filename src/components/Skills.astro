---
const languages: Array<{ label: string; tier: 1 | 2 | 3 }> = [
  { label: "Python",           tier: 1 },
  { label: "TypeScript",       tier: 1 },
  { label: "Java",             tier: 2 },
  { label: "C",                tier: 2 },
  { label: "C++",              tier: 2 },
  { label: "JavaScript",       tier: 3 },
  { label: "SQL / PostgreSQL", tier: 3 },
];

const frameworks = ["React", "Astro", "TailwindCSS", "pygame", "python-chess"];

const tools = ["Git / GitHub", "Linux", "Vite", "Vitest"];

const domains = [
  "Bio-informatique",
  "Programmation système",
  "Machine learning appliqué",
  "Développement web",
];

const tierSize: Record<1 | 2 | 3, string> = {
  1: "2.4rem",
  2: "1.85rem",
  3: "1.3rem",
};
---

<section class="skills" id="skills" aria-labelledby="skills-heading">

  <div class="skills-image" aria-hidden="true">
    <img
      src="/images/04-skills-cells-green.jpg"
      alt=""
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="skills-content">

    <p class="skills-label" aria-hidden="true">03 · Compétences</p>
    <h2 class="skills-title" id="skills-heading">Ce que je maîtrise</h2>

    <!-- LANGAGES -->
    <div class="skills-subsection">
      <p class="subsection-label">Langages</p>
      <div class="skills-cloud lang-cloud">
        {languages.map(l => (
          <span
            class="skill-tag skill-lang"
            style={`font-size: ${tierSize[l.tier]};`}
          >
            {l.label}
          </span>
        ))}
      </div>
    </div>

    <!-- FRAMEWORKS & BIBLIOTHÈQUES -->
    <div class="skills-subsection">
      <p class="subsection-label">Frameworks &amp; Bibliothèques</p>
      <div class="skills-cloud fw-cloud">
        {frameworks.map(f => (
          <span class="skill-tag skill-fw">{f}</span>
        ))}
      </div>
    </div>

    <!-- OUTILS -->
    <div class="skills-subsection">
      <p class="subsection-label">Outils</p>
      <div class="skills-cloud tool-cloud">
        {tools.map(t => (
          <span class="skill-tag skill-tool">{t}</span>
        ))}
      </div>
    </div>

    <!-- DOMAINES D'INTÉRÊT -->
    <div class="skills-subsection">
      <p class="subsection-label">Domaines d'intérêt</p>
      <div class="skills-cloud domain-cloud">
        {domains.map(d => (
          <span class="skill-tag skill-domain">{d}</span>
        ))}
      </div>
    </div>

  </div>

</section>

<style>
  .skills {
    position: relative;
    background-color: var(--bg-primary);
    padding-block: var(--space-16);
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .skills { padding-block: var(--space-12); }
  }

  /* ── Image background ──────────────────────────────── */
  .skills-image {
    position: absolute;
    right: 0;
    top: 0;
    width: 58%;
    height: 100%;
    z-index: 0;
  }

  .skills-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #000000 0%,
      rgba(0, 0, 0, 0.92) 18%,
      rgba(0, 0, 0, 0.65) 40%,
      rgba(0, 0, 0, 0.25) 68%,
      rgba(0, 0, 0, 0.1) 85%,
      transparent 100%
    );
    z-index: 1;
  }

  .skills-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.38) saturate(0.55);
  }

  @media (max-width: 767px) {
    .skills-image {
      width: 100%;
    }
    .skills-image::after {
      background: rgba(0, 0, 0, 0.88);
    }
  }

  /* ── Contenu ──────────────────────────────────────── */
  .skills-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    padding-left: var(--space-8);
    padding-right: var(--space-4);
  }

  @media (max-width: 767px) {
    .skills-content {
      max-width: 100%;
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
  }

  .skills-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .skills-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h1);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-10);
  }

  /* ── Sous-sections ───────────────────────────────── */
  .skills-subsection {
    margin-bottom: var(--space-8);
  }

  .subsection-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: var(--space-2);
  }

  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px 32px;
  }

  @media (max-width: 767px) {
    .skills-cloud { gap: 10px 16px; }
  }

  /* ── Langages ─────────────────────────────────────── */
  .skill-lang {
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-primary);
    line-height: 1;
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-lang:hover {
    color: var(--accent-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Frameworks ───────────────────────────────────── */
  .skill-fw {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.15rem;
    color: var(--text-primary);
    line-height: 1;
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-fw:hover {
    color: var(--accent-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Outils ───────────────────────────────────────── */
  .skill-tool {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1;
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-tool:hover {
    color: var(--text-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  /* ── Domaines ─────────────────────────────────────── */
  .domain-cloud {
    align-items: center;
    gap: 12px 32px;
  }

  .skill-domain {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-secondary);
    cursor: default;
    transition: color var(--duration-micro) var(--ease-out);
  }

  .skill-domain:hover {
    color: var(--text-primary);
    animation: heartbeat 0.45s var(--ease-out);
  }

  @keyframes heartbeat {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.08); }
    55%  { transform: scale(0.97); }
    75%  { transform: scale(1.04); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-lang:hover,
    .skill-fw:hover,
    .skill-tool:hover,
    .skill-domain:hover { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.skills-label, .skills-title', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.skills-content', start: 'top 82%', once: true },
    });

    gsap.from('.skills-subsection', {
      opacity: 0, y: 18, duration: 0.55, stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.skills-content', start: 'top 78%', once: true },
    });

    gsap.from('.skill-lang', {
      opacity: 0, y: 12, duration: 0.5,
      stagger: { amount: 0.45, from: 'start' },
      ease: 'power2.out',
      scrollTrigger: { trigger: '.lang-cloud', start: 'top 82%', once: true },
    });

    gsap.to('.skills-image img', {
      y: '12%', ease: 'none',
      scrollTrigger: {
        trigger: '.skills', start: 'top bottom', end: 'bottom top', scrub: true,
      },
    });
  }
</script>
