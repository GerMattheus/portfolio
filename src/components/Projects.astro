---
interface Project {
  index: string;
  title: string;
  subtitle: string;
  description: string;
  stack: string[];
  context: string;
  status: string;
  githubUrl?: string;
  liveUrl?: string;
  codeNote?: string;
}

const projects: Project[] = [
  {
    index: "01",
    title: "LifeQuest RPG",
    subtitle: "Progressive Web App de développement personnel gamifié",
    description: "Application web qui transforme les habitudes, objectifs et apprentissages quotidiens en système de jeu de rôle. Le personnage progresse à travers 8 compétences (Santé, Discipline, Études, Social, Relations, Finance, Maîtrise de soi, Créativité), accumule de l'XP via des quêtes (quotidiennes, hebdomadaires, mensuelles, personnalisées), répond à des quiz personnalisés, tient un journal et débloque des thèmes visuels via une monnaie virtuelle. Architecture full-frontend avec persistance locale (IndexedDB via Dexie.js), state management par stores Zustand, et installation native via PWA + Service Worker. Aucune donnée n'est envoyée à un serveur — tout reste sur l'appareil de l'utilisateur.",
    stack: ["React 18", "TypeScript", "Vite", "TailwindCSS", "Zustand", "Dexie.js (IndexedDB)", "React Router v6", "Workbox PWA", "Recharts"],
    context: "Projet personnel · Développé avec l'assistance de Claude Code",
    status: "En développement actif",
    githubUrl: "https://github.com/GerMattheus/lifequest-rpg",
    liveUrl: "https://germanolifequest.netlify.app/",
  },
  {
    index: "02",
    title: "Dotaro",
    subtitle: "Réimplémentation moderne du Jeu Chimie de Kinshasa",
    description: "Jeu de stratégie de territoire jouable en local ou à distance, inspiré du Jeu Chimie traditionnel joué en République Démocratique du Congo. Conception d'un moteur de jeu en TypeScript avec détection d'imbrications, gestion de cascades, et multijoueur temps réel via Supabase. Architecture séparée moteur/UI, tests Vitest, PWA installable. Une réimplémentation personnelle du jeu de mon enfance.",
    stack: ["Vanilla TypeScript", "Vite", "Vitest", "Supabase Realtime", "SVG", "Lenis", "PWA"],
    context: "Projet personnel",
    status: "En développement actif",
    githubUrl: "https://github.com/GerMattheus/Dotaro",
  },
  {
    index: "03",
    title: "Chat & transfert RS-232 simulé",
    subtitle: "Programmation système en C — pthreads, tampons circulaires, protocole binaire",
    description: "Implémentation en C d'une application de chat avec transfert de fichiers, communicant entre deux machines virtuelles via une simulation du port série RS-232. Le cœur du système repose sur un tampon circulaire (compilable en kernel-mode ou userspace via macros), surmonté par un protocole binaire à header (FILE:nom:taille) qui distingue les messages texte des transferts binaires. L'application tourne sur trois threads synchronisés par mutex : un reader qui parse les trames entrantes via une machine à états, un writer qui gère l'entrée terminal en mode raw (termios), et un watchdog qui détecte les transferts bloqués (timeout 3 secondes) et sauvegarde les données partielles. Le tout avec affichage de progression en temps réel et récupération gracieuse en cas d'interruption.",
    stack: ["C", "pthreads", "termios", "Linux", "Machines virtuelles", "Programmation système", "Synchronisation"],
    context: "Cours IFT320 — Systèmes d'exploitation · Université de Sherbrooke",
    status: "Terminé · 2025",
    codeNote: "// code disponible sur demande",
  },
];
---

<section class="projects" id="projects" aria-labelledby="projects-heading">

  <!-- Bandeau intro rouge -->
  <div class="projects-banner" aria-hidden="true">
    <div class="projects-banner-img">
      <img
        src="/images/05-projects-cells-red.jpg"
        alt=""
        loading="lazy"
        decoding="async"
        style="filter: brightness(0.65);"
      />
    </div>
    <div class="projects-banner-overlay"></div>
    <div class="projects-banner-text">
      <h2 class="projects-heading" id="projects-heading">Projets</h2>
      <p class="projects-count">— 03 projets sélectionnés</p>
    </div>
  </div>

  <!-- Liste des projets -->
  <div class="projects-list">
    {projects.map(p => (
      <article
        class="project-item"
        data-index={p.index}
        data-title={p.title}
        data-subtitle={p.subtitle}
        data-description={p.description}
        data-stack={p.stack.join('|')}
        data-context={p.context}
        data-status={p.status}
        data-github={p.githubUrl ?? ''}
        data-live={p.liveUrl ?? ''}
        data-code-note={p.codeNote ?? ''}
        role="button"
        tabindex="0"
        aria-label={`Voir le projet ${p.title}`}
      >
        <span class="project-index" aria-hidden="true">{p.index}.</span>

        <div class="project-body">
          <div class="project-top">
            <h3 class="project-title">{p.title}</h3>
            <span class="project-status">{p.status}</span>
          </div>
          <p class="project-subtitle"><em>{p.subtitle}</em></p>
          <div class="project-stack">
            {p.stack.slice(0, 5).map(tag => (
              <span class="stack-tag">{tag}</span>
            ))}
            {p.stack.length > 5 && (
              <span class="stack-tag stack-tag--more">+{p.stack.length - 5}</span>
            )}
          </div>
        </div>

        <span class="project-arrow" aria-hidden="true">→</span>
      </article>
    ))}
  </div>

  <!-- Modal -->
  <dialog class="project-modal" id="project-modal" aria-modal="true">
    <div class="modal-inner">
      <button class="modal-close" id="modal-close" aria-label="Fermer">✕</button>

      <div class="modal-header">
        <span class="modal-index" id="modal-index"></span>
        <h3 class="modal-title" id="modal-title"></h3>
        <p class="modal-subtitle" id="modal-subtitle"></p>
      </div>

      <p class="modal-description" id="modal-description"></p>

      <div class="modal-stack" id="modal-stack"></div>

      <div class="modal-meta">
        <span class="modal-context" id="modal-context"></span>
        <span class="modal-status" id="modal-status"></span>
      </div>

      <div class="modal-links" id="modal-links"></div>
    </div>
  </dialog>

</section>

<style>
  .projects {
    background-color: var(--bg-primary);
  }

  /* ── Bandeau intro ───────────────────────────────── */
  .projects-banner {
    position: relative;
    height: 42vh;
    overflow: hidden;
  }

  .projects-banner-img {
    position: absolute;
    inset: -8% 0;
    height: 116%;
  }

  .projects-banner-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .projects-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      #000000 100%
    );
    z-index: 1;
  }

  .projects-banner-text {
    position: absolute;
    bottom: var(--space-8);
    left: var(--space-8);
    z-index: 2;
  }

  .projects-heading {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .projects-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
    letter-spacing: 0.06em;
    margin-top: var(--space-1);
  }

  @media (max-width: 767px) {
    .projects-banner { height: 32vh; }
    .projects-banner-text { left: var(--space-4); bottom: var(--space-4); }
  }

  /* ── Liste ───────────────────────────────────────── */
  .projects-list {
    padding-bottom: var(--space-12);
  }

  /* ── Carte projet — rangée compacte ─────────────── */
  .project-item {
    display: grid;
    grid-template-columns: 3.5rem 1fr 1.5rem;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-6) var(--space-8);
    border-top: 1px solid var(--border-subtle);
    border-left: 2px solid transparent;
    cursor: pointer;
    transition:
      background var(--duration-micro) var(--ease-out),
      border-left-color var(--duration-base) var(--ease-out);
    outline: none;
  }

  .project-item:last-child {
    border-bottom: 1px solid var(--border-subtle);
  }

  .project-item:hover,
  .project-item:focus-visible {
    background: var(--bg-secondary);
    border-left-color: var(--accent-primary);
  }

  .project-item:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: -2px;
  }

  @media (max-width: 767px) {
    .project-item {
      grid-template-columns: 2.5rem 1fr 1rem;
      gap: var(--space-3);
      padding: var(--space-5) var(--space-4);
    }
  }

  /* Numéro */
  .project-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    align-self: start;
    padding-top: 4px;
  }

  /* Corps */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .project-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .project-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: clamp(1.25rem, 2.5vw, var(--text-h3));
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .project-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-subtitle {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-size: var(--text-small);
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* Stack tags */
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 4px var(--space-2);
    margin-top: var(--space-1);
  }

  .stack-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 2px 8px;
    line-height: 1.6;
  }

  .stack-tag--more {
    border-style: dashed;
  }

  /* Flèche */
  .project-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    transition: color var(--duration-micro) var(--ease-out), transform var(--duration-micro) var(--ease-out);
    justify-self: end;
  }

  .project-item:hover .project-arrow {
    color: var(--accent-cool);
    transform: translateX(3px);
  }

  /* ── Modal ───────────────────────────────────────── */
  dialog {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    max-width: 700px;
    width: 92%;
    padding: 0;
    border-radius: 2px;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .modal-inner {
    padding: var(--space-8);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (max-width: 640px) {
    .modal-inner { padding: var(--space-5) var(--space-4); }
  }

  .modal-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 32px;
    height: 32px;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-micro), border-color var(--duration-micro);
  }

  .modal-close:hover {
    color: var(--text-primary);
    border-color: var(--text-muted);
  }

  .modal-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-right: var(--space-8);
  }

  .modal-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.1em;
  }

  .modal-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h2);
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .modal-subtitle {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  .modal-description {
    color: var(--text-secondary);
    line-height: 1.72;
    border-left: 2px solid var(--border-subtle);
    padding-left: var(--space-3);
  }

  .modal-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
  }

  .modal-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modal-context,
  .modal-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  .modal-status { color: var(--accent-primary); }

  .modal-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-subtle);
  }

  .modal-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-cool);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 6px 14px;
    transition: color var(--duration-micro), border-color var(--duration-micro);
  }

  .modal-link:hover {
    color: var(--text-primary);
    border-color: var(--accent-cool);
  }

  .modal-code-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    align-self: center;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.projects-heading, .projects-count', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1, ease: 'power2.out',
      scrollTrigger: { trigger: '.projects-banner', start: 'top 80%', once: true },
    });

    gsap.from('.project-item', {
      opacity: 0, y: 20, duration: 0.5, stagger: 0.12, ease: 'power2.out',
      scrollTrigger: { trigger: '.projects-list', start: 'top 82%', once: true },
    });

    gsap.to('.projects-banner-img', {
      y: '15%', ease: 'none',
      scrollTrigger: {
        trigger: '.projects-banner',
        start: 'top bottom', end: 'bottom top', scrub: true,
      },
    });
  }

  /* ── Modal ───────────────────────────────────────── */
  const dialog = document.getElementById('project-modal') as HTMLDialogElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;
  const $id = (id: string) => document.getElementById(id) as HTMLElement;

  function openModal(card: HTMLElement): void {
    const stack = card.dataset.stack?.split('|') ?? [];
    const github = card.dataset.github ?? '';
    const live = card.dataset.live ?? '';
    const codeNote = card.dataset.codeNote ?? '';

    $id('modal-index').textContent    = `Projet ${card.dataset.index}`;
    $id('modal-title').textContent    = card.dataset.title ?? '';
    $id('modal-subtitle').textContent = card.dataset.subtitle ?? '';
    $id('modal-description').textContent = card.dataset.description ?? '';
    $id('modal-context').textContent  = card.dataset.context ?? '';
    $id('modal-status').textContent   = card.dataset.status ?? '';

    $id('modal-stack').innerHTML = stack
      .map(t => `<span class="stack-tag">${t}</span>`)
      .join('');

    const linksEl = $id('modal-links');
    linksEl.innerHTML = '';
    if (github) linksEl.innerHTML += `<a class="modal-link" href="${github}" target="_blank" rel="noopener noreferrer">GitHub ↗</a>`;
    if (live)   linksEl.innerHTML += `<a class="modal-link" href="${live}" target="_blank" rel="noopener noreferrer">Voir le site ↗</a>`;
    if (codeNote) linksEl.innerHTML += `<span class="modal-code-note">${codeNote}</span>`;

    dialog.showModal();
    if (!reduced) {
      gsap.from('.modal-inner', { opacity: 0, y: 14, duration: 0.3, ease: 'power2.out' });
    }
  }

  document.querySelectorAll<HTMLElement>('.project-item').forEach(card => {
    card.addEventListener('click', () => openModal(card));
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(card); }
    });
  });

  closeBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });
</script>
