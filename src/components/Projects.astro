---
interface Project {
  index: string;
  title: string;
  subtitle: string;
  description: string;
  stack: string[];
  context: string;
  status: string;
  githubUrl?: string;
  liveUrl?: string;
  codeNote?: string;
  layout: 'showcase' | 'right' | 'left';
}

const projects: Project[] = [
  {
    index: "01",
    title: "LifeQuest RPG",
    subtitle: "Progressive Web App de développement personnel gamifié",
    description: "Application web qui transforme les habitudes, objectifs et apprentissages quotidiens en système de jeu de rôle. Le personnage progresse à travers 8 compétences (Santé, Discipline, Études, Social, Relations, Finance, Maîtrise de soi, Créativité), accumule de l'XP via des quêtes (quotidiennes, hebdomadaires, mensuelles, personnalisées), répond à des quiz personnalisés, tient un journal et débloque des thèmes visuels via une monnaie virtuelle. Architecture full-frontend avec persistance locale (IndexedDB via Dexie.js), state management par stores Zustand, et installation native via PWA + Service Worker. Aucune donnée n'est envoyée à un serveur — tout reste sur l'appareil de l'utilisateur.",
    stack: ["React 18", "TypeScript", "Vite", "TailwindCSS", "Zustand", "Dexie.js (IndexedDB)", "React Router v6", "Workbox PWA", "Recharts"],
    context: "Projet personnel · Développé avec l'assistance de Claude Code",
    status: "En développement actif",
    githubUrl: "https://github.com/GerMattheus/lifequest-rpg",
    liveUrl: "https://germanolifequest.netlify.app/",
    layout: "showcase",
  },
  {
    index: "02",
    title: "Dotaro",
    subtitle: "Réimplémentation moderne du Jeu Chimie de Kinshasa",
    description: "Jeu de stratégie de territoire jouable en local ou à distance, inspiré du Jeu Chimie traditionnel joué en République Démocratique du Congo. Conception d'un moteur de jeu en TypeScript avec détection d'imbrications, gestion de cascades, et multijoueur temps réel via Supabase. Architecture séparée moteur/UI, tests Vitest, PWA installable. Une réimplémentation personnelle du jeu de mon enfance.",
    stack: ["Vanilla TypeScript", "Vite", "Vitest", "Supabase Realtime", "SVG", "Lenis", "PWA"],
    context: "Projet personnel",
    status: "En développement actif",
    githubUrl: "https://github.com/GerMattheus/Dotaro",
    layout: "right",
  },
  {
    index: "03",
    title: "Chat & transfert RS-232 simulé",
    subtitle: "Programmation système en C — pthreads, tampons circulaires, protocole binaire",
    description: "Implémentation en C d'une application de chat avec transfert de fichiers, communicant entre deux machines virtuelles via une simulation du port série RS-232. Le cœur du système repose sur un tampon circulaire (compilable en kernel-mode ou userspace via macros), surmonté par un protocole binaire à header (FILE:nom:taille) qui distingue les messages texte des transferts binaires. L'application tourne sur trois threads synchronisés par mutex : un reader qui parse les trames entrantes via une machine à états, un writer qui gère l'entrée terminal en mode raw (termios), et un watchdog qui détecte les transferts bloqués (timeout 3 secondes) et sauvegarde les données partielles. Le tout avec affichage de progression en temps réel et récupération gracieuse en cas d'interruption.",
    stack: ["C", "pthreads", "termios", "Linux", "Machines virtuelles", "Programmation système", "Synchronisation"],
    context: "Cours IFT320 — Systèmes d'exploitation · Université de Sherbrooke",
    status: "Terminé · 2025",
    codeNote: "// code disponible sur demande",
    layout: "left",
  },
];
---

<section class="projects" id="projects" aria-labelledby="projects-heading">

  <!-- Bandeau intro rouge : 05-projects-cells-red.jpg -->
  <div class="projects-banner" aria-hidden="true">
    <div class="projects-banner-img">
      <img
        src="/images/05-projects-cells-red.jpg"
        alt=""
        loading="lazy"
        decoding="async"
        style="filter: brightness(0.65);"
      />
    </div>
    <div class="projects-banner-overlay"></div>
    <div class="projects-banner-text">
      <h2 class="projects-heading" id="projects-heading">Projets</h2>
      <p class="projects-count">— 03 projets sélectionnés</p>
    </div>
  </div>

  <!-- Grille des projets -->
  <div class="projects-list">
    {projects.map(p => (
      <article
        class={`project-item project-item--${p.layout}`}
        data-index={p.index}
        data-title={p.title}
        data-subtitle={p.subtitle}
        data-description={p.description}
        data-stack={p.stack.join('|')}
        data-context={p.context}
        data-status={p.status}
        data-github={p.githubUrl ?? ''}
        data-live={p.liveUrl ?? ''}
        data-code-note={p.codeNote ?? ''}
        role="button"
        tabindex="0"
        aria-label={`Voir le projet ${p.title}`}
      >
        <!-- Zone visuelle -->
        <div class="project-visual" aria-hidden="true">
          <span class="project-visual-index">{p.index}.</span>
        </div>

        <!-- Infos -->
        <div class="project-info">
          <span class="project-index" aria-hidden="true">{p.index}.</span>
          <h3 class="project-title">{p.title}</h3>
          <p class="project-subtitle"><em>{p.subtitle}</em></p>

          <div class="project-stack">
            {p.stack.slice(0, 4).map(tag => (
              <span class="stack-tag">{tag}</span>
            ))}
            {p.stack.length > 4 && (
              <span class="stack-tag stack-tag--more">+{p.stack.length - 4}</span>
            )}
          </div>

          <div class="project-footer">
            <span class="project-status">{p.status}</span>
            <button class="project-cta" aria-label={`Voir les détails de ${p.title}`}>
              Voir le projet →
            </button>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Modal projet — dialog natif -->
  <dialog class="project-modal" id="project-modal" aria-modal="true">
    <div class="modal-inner">
      <button class="modal-close" id="modal-close" aria-label="Fermer">✕</button>

      <div class="modal-header">
        <span class="modal-index" id="modal-index"></span>
        <h3 class="modal-title" id="modal-title"></h3>
        <p class="modal-subtitle" id="modal-subtitle"></p>
      </div>

      <p class="modal-description" id="modal-description"></p>

      <div class="modal-stack" id="modal-stack"></div>

      <div class="modal-meta">
        <span class="modal-context" id="modal-context"></span>
        <span class="modal-status" id="modal-status"></span>
      </div>

      <div class="modal-links" id="modal-links"></div>
    </div>
  </dialog>

</section>

<style>
  /* ── Section ──────────────────────────────────────── */
  .projects {
    background-color: var(--bg-primary);
  }

  /* ── Bandeau intro ───────────────────────────────── */
  .projects-banner {
    position: relative;
    height: 45vh;
    overflow: hidden;
  }

  .projects-banner-img {
    position: absolute;
    inset: -8% 0;
    height: 116%;
  }

  .projects-banner-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Overlay sombre bas pour raccord avec la liste */
  .projects-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.15) 50%,
      #000000 100%
    );
    z-index: 1;
  }

  .projects-banner-text {
    position: absolute;
    bottom: var(--space-8);
    left: var(--space-8);
    z-index: 2;
  }

  .projects-heading {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .projects-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
    letter-spacing: 0.06em;
    margin-top: var(--space-1);
  }

  @media (max-width: 767px) {
    .projects-banner {
      height: 35vh;
    }
    .projects-banner-text {
      left: var(--space-4);
      bottom: var(--space-4);
    }
  }

  /* ── Liste des projets ───────────────────────────── */
  .projects-list {
    padding: var(--space-12) 0 var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 767px) {
    .projects-list {
      padding: var(--space-8) 0 var(--space-12);
      gap: var(--space-3);
    }
  }

  /* ── Carte projet ─────────────────────────────────── */
  .project-item {
    display: grid;
    align-items: stretch;
    cursor: pointer;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    transition: background var(--duration-micro) var(--ease-out);
    outline: none;
  }

  .project-item:hover,
  .project-item:focus-visible {
    background: var(--bg-secondary);
  }

  .project-item:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: -2px;
  }

  /* Showcase : plein largeur, visuel gauche 55% / info droite 45% */
  .project-item--showcase {
    grid-template-columns: 55fr 45fr;
    min-height: 380px;
  }

  /* Right : info gauche 42% / visuel droite 58% */
  .project-item--right {
    grid-template-columns: 42fr 58fr;
    min-height: 320px;
  }

  .project-item--right .project-visual {
    order: 2;
  }

  .project-item--right .project-info {
    order: 1;
  }

  /* Left : visuel gauche 58% / info droite 42% */
  .project-item--left {
    grid-template-columns: 58fr 42fr;
    min-height: 320px;
  }

  /* Mobile : tout en pleine largeur, empilés */
  @media (max-width: 767px) {
    .project-item--showcase,
    .project-item--right,
    .project-item--left {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .project-item--right .project-visual,
    .project-item--right .project-info {
      order: unset;
    }

    .project-visual {
      min-height: 160px;
    }
  }

  /* ── Zone visuelle ───────────────────────────────── */
  .project-visual {
    position: relative;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-right: 1px solid var(--border-subtle);
  }

  .project-item--right .project-visual {
    border-right: none;
    border-left: 1px solid var(--border-subtle);
  }

  /* Numéro en gros derrière */
  .project-visual-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(5rem, 12vw, 10rem);
    color: var(--border);
    line-height: 1;
    user-select: none;
    transition: color var(--duration-base) var(--ease-out);
  }

  .project-item:hover .project-visual-index {
    color: var(--border-subtle);
  }

  /* ── Infos projet ────────────────────────────────── */
  .project-info {
    padding: var(--space-8) var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-3);
  }

  @media (max-width: 767px) {
    .project-info {
      padding: var(--space-5) var(--space-4);
    }
  }

  .project-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .project-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h2);
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .project-subtitle {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-size: var(--text-small);
    color: var(--text-secondary);
    line-height: 1.45;
  }

  /* Stack tags */
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
  }

  .stack-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 3px 10px;
    line-height: 1.6;
  }

  .stack-tag--more {
    color: var(--text-muted);
    border-style: dashed;
  }

  /* Pied de carte */
  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-1);
  }

  .project-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  .project-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-cool);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color var(--duration-micro) var(--ease-out);
    pointer-events: none; /* le click est sur l'article */
  }

  .project-item:hover .project-cta {
    color: var(--accent-primary);
  }

  /* ── Modal ───────────────────────────────────────── */
  dialog {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    max-width: 700px;
    width: 92%;
    padding: 0;
    border-radius: 2px;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .modal-inner {
    padding: var(--space-8);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (max-width: 640px) {
    .modal-inner {
      padding: var(--space-5) var(--space-4);
    }
  }

  .modal-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 32px;
    height: 32px;
    cursor: pointer;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-micro), border-color var(--duration-micro);
  }

  .modal-close:hover {
    color: var(--text-primary);
    border-color: var(--text-muted);
  }

  .modal-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-right: var(--space-8);
  }

  .modal-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.1em;
  }

  .modal-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h2);
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .modal-subtitle {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-style: italic;
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  .modal-description {
    color: var(--text-secondary);
    line-height: 1.72;
    border-left: 2px solid var(--border-subtle);
    padding-left: var(--space-3);
  }

  .modal-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
  }

  .modal-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modal-context,
  .modal-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }

  .modal-status {
    color: var(--accent-primary);
  }

  .modal-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-subtle);
  }

  .modal-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-cool);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 6px 14px;
    transition: color var(--duration-micro), border-color var(--duration-micro);
  }

  .modal-link:hover {
    color: var(--text-primary);
    border-color: var(--accent-cool);
  }

  .modal-code-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
    align-self: center;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /* ── Scroll reveals ──────────────────────────────── */
  gsap.from('.projects-heading, .projects-count', {
    opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
    ease: 'power2.out',
    scrollTrigger: { trigger: '.projects-banner', start: 'top 80%', once: true },
  });

  gsap.from('.project-item', {
    opacity: 0, y: 28, duration: 0.6, stagger: 0.18,
    ease: 'power2.out',
    scrollTrigger: { trigger: '.projects-list', start: 'top 82%', once: true },
  });

  /* Parallax léger sur le bandeau */
  gsap.to('.projects-banner-img', {
    y: '15%',
    ease: 'none',
    scrollTrigger: {
      trigger: '.projects-banner',
      start: 'top bottom',
      end: 'bottom top',
      scrub: true,
    },
  });

  /* ── Modal ───────────────────────────────────────── */
  const dialog = document.getElementById('project-modal') as HTMLDialogElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;

  const $id = (id: string) => document.getElementById(id) as HTMLElement;

  function openModal(card: HTMLElement) {
    const stack = card.dataset.stack?.split('|') ?? [];
    const github = card.dataset.github ?? '';
    const live = card.dataset.live ?? '';
    const codeNote = card.dataset.codeNote ?? '';

    $id('modal-index').textContent    = `Projet ${card.dataset.index}`;
    $id('modal-title').textContent    = card.dataset.title ?? '';
    $id('modal-subtitle').textContent = card.dataset.subtitle ?? '';
    $id('modal-description').textContent = card.dataset.description ?? '';
    $id('modal-context').textContent  = card.dataset.context ?? '';
    $id('modal-status').textContent   = card.dataset.status ?? '';

    /* Tags stack */
    const stackEl = $id('modal-stack');
    stackEl.innerHTML = stack
      .map(t => `<span class="stack-tag">${t}</span>`)
      .join('');

    /* Liens */
    const linksEl = $id('modal-links');
    linksEl.innerHTML = '';

    if (github) {
      linksEl.innerHTML += `<a class="modal-link" href="${github}" target="_blank" rel="noopener noreferrer">GitHub ↗</a>`;
    }
    if (live) {
      linksEl.innerHTML += `<a class="modal-link" href="${live}" target="_blank" rel="noopener noreferrer">Voir le site ↗</a>`;
    }
    if (codeNote) {
      linksEl.innerHTML += `<span class="modal-code-note">${codeNote}</span>`;
    }

    dialog.showModal();
    gsap.from('.modal-inner', {
      opacity: 0, y: 16, duration: 0.35, ease: 'power2.out',
    });
  }

  /* Clic sur une carte */
  document.querySelectorAll<HTMLElement>('.project-item').forEach(card => {
    card.addEventListener('click', () => openModal(card));
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(card);
      }
    });
  });

  /* Fermeture */
  closeBtn.addEventListener('click', () => dialog.close());

  dialog.addEventListener('click', e => {
    if (e.target === dialog) dialog.close();
  });
</script>
