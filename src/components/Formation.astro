---
const entries = [
  {
    index: "01",
    degree: "Baccalauréat en informatique",
    detail: "Régime coopératif",
    institution: "Université de Sherbrooke",
    period: "2024 — 2027",
    note: "En cours",
  },
  {
    index: "02",
    degree: "Certificat préparatoire",
    detail: "Programmes de 1er cycle",
    institution: "Université de Sherbrooke",
    period: "2023 — 2024",
    note: "27 / 30 crédits",
  },
  {
    index: "03",
    degree: "Diplôme en Biologie-Chimie",
    detail: "Équivalent études secondaires",
    institution: "Collège Saint Étienne",
    period: "2014 — 2020",
    note: "Kinshasa, RDCongo",
  },
];
---

<section class="formation" id="formation" aria-labelledby="formation-heading">
  <div class="formation-content">

    <p class="formation-label" id="formation-heading">02 · Formation</p>

    <div class="formation-list">
      {entries.map(e => (
        <article class="formation-card">
          <span class="card-index" aria-hidden="true">{e.index}.</span>

          <div class="card-main">
            <h3 class="card-degree">{e.degree}</h3>
            <p class="card-detail">{e.detail}</p>
          </div>

          <div class="card-meta">
            <span class="card-institution">{e.institution}</span>
            <span class="card-period">{e.period}</span>
            {e.note && <span class="card-note">{e.note}</span>}
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .formation {
    background-color: var(--bg-primary);
    padding-block: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 767px) {
    .formation { padding-block: var(--space-6); }
  }

  /* ── Contenu centré ──────────────────────────────── */
  .formation-content {
    max-width: 860px;
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  @media (max-width: 767px) {
    .formation-content {
      padding-inline: var(--space-4);
    }
  }

  .formation-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  /* ── Cartes ──────────────────────────────────────── */
  .formation-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .formation-card {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid transparent;
    transition:
      border-left-color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out);
  }

  .formation-card:hover {
    border-left-color: var(--accent-primary);
    background: var(--bg-tertiary);
  }

  @media (max-width: 600px) {
    .formation-card {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-2);
    }
    .card-meta { grid-column: 2 / -1; }
  }

  .card-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    color: var(--text-muted);
    line-height: 1;
  }

  .card-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-degree {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h3);
    color: var(--text-primary);
    line-height: 1.2;
    font-weight: 400;
  }

  .card-detail {
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .card-institution {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
  }

  .card-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.04em;
  }

  .card-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.formation-label', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.formation-content', start: 'top 82%', once: true },
    });

    gsap.from('.formation-card', {
      opacity: 0, y: 24, duration: 0.55, stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.formation-list', start: 'top 80%', once: true },
    });
  }
</script>
