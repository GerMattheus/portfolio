---
const entries = [
  {
    index: "01",
    degree: "Baccalauréat en informatique",
    detail: "Régime coopératif",
    institution: "Université de Sherbrooke",
    period: "2024 — 2027",
    note: "",
  },
  {
    index: "02",
    degree: "Certificat préparatoire",
    detail: "Programmes de 1er cycle",
    institution: "Université de Sherbrooke",
    period: "2023 — 2024",
    note: "27 / 30 crédits",
  },
];
---

<section class="formation" id="formation" aria-labelledby="formation-heading">
  <div class="formation-container">

    <p class="section-label" aria-hidden="true">02 · Formation</p>
    <h2 class="section-title" id="formation-heading">Parcours</h2>

    <div class="formation-list">
      {entries.map(e => (
        <article class="formation-card">
          <span class="card-index" aria-hidden="true">{e.index}.</span>

          <div class="card-main">
            <h3 class="card-degree">{e.degree}</h3>
            <p class="card-detail">{e.detail}</p>
          </div>

          <div class="card-meta">
            <span class="card-institution">{e.institution}</span>
            <span class="card-period">{e.period}</span>
            {e.note && <span class="card-note">{e.note}</span>}
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .formation {
    background-color: var(--bg-primary);
    padding-block: var(--space-16);
  }

  .formation-container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  @media (max-width: 767px) {
    .formation { padding-block: var(--space-12); }
    .formation-container { padding-inline: var(--space-4); }
  }

  /* Étiquette et titre */
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h1);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-8);
  }

  /* Cartes horizontales asymétriques */
  .formation-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 900px;
  }

  .formation-card {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    /* barre gauche cachée par défaut */
    border-left: 2px solid transparent;
    transition:
      border-color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out);
  }

  .formation-card:hover {
    border-left-color: var(--accent-primary);
    background: var(--bg-tertiary);
  }

  @media (max-width: 640px) {
    .formation-card {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
      padding: var(--space-4);
      gap: var(--space-2);
    }

    .card-meta {
      grid-column: 2 / -1;
    }
  }

  /* Numéro */
  .card-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    color: var(--text-muted);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  /* Contenu principal */
  .card-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-degree {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h3);
    color: var(--text-primary);
    line-height: 1.2;
    font-weight: 400;
  }

  .card-detail {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  /* Métadonnées (droite) */
  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .card-institution {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .card-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.04em;
  }

  .card-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.formation .section-label, .formation .section-title', {
    opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
    ease: 'power2.out',
    scrollTrigger: { trigger: '.formation', start: 'top 82%', once: true },
  });

  gsap.from('.formation-card', {
    opacity: 0, y: 24, duration: 0.55, stagger: 0.15,
    ease: 'power2.out',
    scrollTrigger: { trigger: '.formation-list', start: 'top 80%', once: true },
  });
</script>
