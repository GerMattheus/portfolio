---
const entries = [
  {
    index: "01",
    degree: "Baccalauréat en informatique",
    detail: "Régime coopératif",
    institution: "Université de Sherbrooke",
    period: "2024 — 2027",
    note: "",
  },
  {
    index: "02",
    degree: "Certificat préparatoire",
    detail: "Programmes de 1er cycle",
    institution: "Université de Sherbrooke",
    period: "2023 — 2024",
    note: "27 / 30 crédits",
  },
];
---

<section class="formation" id="formation" aria-labelledby="formation-heading">

  <!-- Image droite — Modèle A — 08-texture-black-sand (sombre natif) -->
  <div class="formation-image" aria-hidden="true">
    <img
      src="/images/08-texture-black-sand.jpg"
      alt=""
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Contenu gauche — aligné à gauche -->
  <div class="formation-content">

    <p class="formation-label" aria-hidden="true">02 · Formation</p>
    <h2 class="formation-title" id="formation-heading">Parcours</h2>

    <div class="formation-list">
      {entries.map(e => (
        <article class="formation-card">
          <span class="card-index" aria-hidden="true">{e.index}.</span>

          <div class="card-main">
            <h3 class="card-degree">{e.degree}</h3>
            <p class="card-detail">{e.detail}</p>
          </div>

          <div class="card-meta">
            <span class="card-institution">{e.institution}</span>
            <span class="card-period">{e.period}</span>
            {e.note && <span class="card-note">{e.note}</span>}
          </div>
        </article>
      ))}
    </div>

  </div>

</section>

<style>
  .formation {
    position: relative;
    background-color: var(--bg-primary);
    padding-block: var(--space-16);
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .formation { padding-block: var(--space-12); }
  }

  /* ── Image droite (Modèle A) ─────────────────────── */
  .formation-image {
    position: absolute;
    right: 0;
    top: 0;
    width: 58%;
    height: 100%;
    z-index: 0;
  }

  /* Gradient très progressif sur 85% de la largeur */
  .formation-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #000000 0%,
      rgba(0, 0, 0, 0.92) 18%,
      rgba(0, 0, 0, 0.7) 38%,
      rgba(0, 0, 0, 0.3) 62%,
      rgba(0, 0, 0, 0.1) 80%,
      transparent 100%
    );
    z-index: 1;
  }

  .formation-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Renforcer les noirs de la texture sable */
    filter: brightness(0.7) contrast(1.1);
  }

  @media (max-width: 767px) {
    .formation-image {
      width: 100%;
    }

    .formation-image::after {
      background: rgba(0, 0, 0, 0.85);
    }
  }

  /* ── Contenu gauche, calé à gauche ──────────────── */
  .formation-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    padding-left: var(--space-8);
    padding-right: var(--space-4);
  }

  @media (max-width: 767px) {
    .formation-content {
      max-width: 100%;
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
  }

  .formation-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .formation-title {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h1);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-8);
  }

  /* ── Cartes ──────────────────────────────────────── */
  .formation-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .formation-card {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-5);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid transparent;
    transition:
      border-left-color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out);
  }

  .formation-card:hover {
    border-left-color: var(--accent-primary);
    background: var(--bg-tertiary);
  }

  @media (max-width: 600px) {
    .formation-card {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
      padding: var(--space-4);
      gap: var(--space-2);
    }

    .card-meta { grid-column: 2 / -1; }
  }

  .card-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    color: var(--text-muted);
    line-height: 1;
  }

  .card-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-degree {
    font-family: 'Fraunces Variable', 'Fraunces', serif;
    font-size: var(--text-h3);
    color: var(--text-primary);
    line-height: 1.2;
    font-weight: 400;
  }

  .card-detail {
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .card-institution {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-secondary);
  }

  .card-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--accent-primary);
    letter-spacing: 0.04em;
  }

  .card-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-mono);
    color: var(--text-muted);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    gsap.from('.formation-label, .formation-title', {
      opacity: 0, y: 20, duration: 0.6, stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.formation-content', start: 'top 82%', once: true },
    });

    gsap.from('.formation-card', {
      opacity: 0, y: 24, duration: 0.55, stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.formation-list', start: 'top 80%', once: true },
    });

    gsap.to('.formation-image img', {
      y: '10%', ease: 'none',
      scrollTrigger: {
        trigger: '.formation', start: 'top bottom', end: 'bottom top', scrub: true,
      },
    });
  }
</script>
